# =============================================================================
# MySQL Configuration: Enable Binary Logging for CDC (Debezium)
# =============================================================================
# This file is mounted into the MySQL container at:
#   /etc/mysql/conf.d/my.cnf
# =============================================================================

[mysqld]

# --- Binary Log Settings (REQUIRED for CDC) ----------------------------------

# Enable binary logging (records all data changes as events)
log_bin = mysql-bin

# Use ROW format so Debezium receives the actual before/after column values
binlog_format = ROW

# Log full row images for UPDATE/DELETE (required by Debezium)
binlog_row_image = FULL

# Expire binlog logs after 7 days to manage disk space
binlog_expire_logs_seconds = 604800

# --- Replication Identity ----------------------------------------------------

# Unique server ID required for replication/CDC
server-id = 1

# --- GTID Settings (recommended for production reliability) ------------------

# Enable Global Transaction IDs for more robust CDC offset tracking
gtid_mode = ON
enforce_gtid_consistency = ON

# --- Performance -------------------------------------------------------------

# Flush binlog on every transaction commit (safer, slight perf trade-off)
sync_binlog = 1

# --- Character Set -----------------------------------------------------------
character-set-server = utf8mb4
collation-server     = utf8mb4_unicode_ci
